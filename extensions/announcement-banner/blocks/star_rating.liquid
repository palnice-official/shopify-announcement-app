{% if shop.metafields.my_app.announcement != blank %}
  <div
    id="announcement-banner"
    style="
      background-color: {{ block.settings.background_color }};
      color: {{ block.settings.text_color }};
      text-align: center;
      padding: 12px 20px;
      font-size: {{ block.settings.font_size }}px;
      font-weight: 500;
      width: 100%;
      position: relative;
      z-index: 999;
    "
  >
    {{ shop.metafields.my_app.announcement.value }}
  </div>
{% endif %}
<span>test-nice-banner</span>

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFEB3B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    }
  ]
}
{% endschema %}