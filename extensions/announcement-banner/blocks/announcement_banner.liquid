<div
  id="announcement-banner"
  style="
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: #FFEB3B;
    color: #000000;
    text-align: center;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 500;
    width: 100%;
    z-index: 9999;
    box-sizing: border-box;
  "
>
  {% if shop.metafields.my_app.announcement %}
    {{ shop.metafields.my_app.announcement.value }}
  {% else %}
    <!-- Debugging: No announcement metafield found -->
  {% endif %}
</div>

<style>
  body {
    padding-top: 50px;
  }
</style>

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": []
}
{% endschema %}